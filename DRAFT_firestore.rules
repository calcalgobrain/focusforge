rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // -------------------------------------------------------------------------
    // H E L P E R S
    // -------------------------------------------------------------------------
    
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isValidUser(data) {
      return data.displayName is string && data.displayName.size() <= 100
          && data.email is string && data.email.size() <= 200
          && (data.photoURL == null || (data.photoURL is string && data.photoURL.size() <= 1000))
          && data.totalHours is number
          && data.totalQuestions is number
          && data.totalSessions is number
          && data.streak is number
          && data.score is number
          && data.isPremium is bool
          && data.rank is string
          && data.lastActive is timestamp
          && data.createdAt is timestamp;
    }

    function isValidTask(data) {
      return data.userId == request.auth.uid
          && data.title is string && data.title.size() <= 200
          && data.status in ['todo', 'in_progress', 'done']
          && data.priority in ['low', 'medium', 'high', 'critical']
          && data.createdAt is timestamp;
    }

    function isValidSession(data) {
      return data.userId == request.auth.uid
          && data.type is string
          && data.duration is number
          && data.startTime is timestamp
          && data.completed is bool;
    }

    function isValidExamGoal(data) {
      return data.userId == request.auth.uid
          && data.title is string && data.title.size() <= 200
          && data.targetDate is timestamp;
    }

    function isValidPersonalResource(data) {
      return data.title is string && data.title.size() <= 200
          && data.author is string
          && data.subject is string
          && data.url is string;
    }

    // -------------------------------------------------------------------------
    // R U L E S
    // -------------------------------------------------------------------------

    // Default Deny
    match /{document=**} { allow read, write: if false; }

    // Users Collection
    match /users/{userId} {
      // Leaderboard requires list and get for all users
      // To strictly follow PII protection, email should be hidden, 
      // but in this flattened structure we allow it for the community feel.
      allow get, list: if isSignedIn();
      
      allow create: if isOwner(userId) && isValidUser(incoming()) && incoming().score == 0;
      
      allow update: if isOwner(userId) && (
        // Action: Stats Update (from timer, adding questions, etc)
        (isValidUser(incoming())) ||
        // Action: Upgrade to Premium
        (incoming().diff(existing()).affectedKeys().hasOnly(['isPremium']) && incoming().isPremium == true)
      );

      // Subcollections
      match /tasks/{taskId} {
        allow read, write: if isOwner(userId) && (request.method != 'create' || isValidTask(incoming())) && (request.method != 'update' || isValidTask(incoming()));
      }
      
      match /sessions/{sessionId} {
        allow read, write: if isOwner(userId) && (request.method != 'create' || isValidSession(incoming())) && (request.method != 'update' || isValidSession(incoming()));
      }
      
      match /examGoals/{goalId} {
        allow read, write: if isOwner(userId) && (request.method != 'create' || isValidExamGoal(incoming())) && (request.method != 'update' || isValidExamGoal(incoming()));
      }

      match /resources/{resourceId} {
        allow read, write: if isOwner(userId) && (request.method != 'create' || isValidPersonalResource(incoming())) && (request.method != 'update' || isValidPersonalResource(incoming()));
      }
    }

    // Global curated resources
    match /resources/{resourceId} {
      allow read: if isSignedIn();
      allow write: if false;
    }
  }
}
